function TabProto:CreateSlider(name, min, max, default, suffix, callback)
    local lib = self.Library
    min = min or 0
    max = max or 100
    local value = Clamp(default or min, min, max)
    suffix = suffix or ""
    
    local slider = {Type = "Slider", Root = nil, Value = value}
    
    slider.Root = Create("Frame", {
        Name = "SliderFrame_" .. name,
        BackgroundTransparency = 0,
        BackgroundColor3 = lib.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 48),
        LayoutOrder = #self.Elements + 1,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, slider.Root)
    
    -- Name and value
    local nameLabel = Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = lib.Theme.TextColor,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, 10, 0, 6),
        Size = UDim2.new(0, 140, 0, 18),
        Parent = slider.Root,
    })
    
    local valueLabel = Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = tostring(RoundNumber(value, 1)) .. suffix,
        TextColor3 = lib.Theme.AccentColor,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Position = UDim2.new(1, -80, 0, 6),
        Size = UDim2.new(0, 70, 0, 18),
        Parent = slider.Root,
    })
    
    -- Slider background
    local sliderBg = Create("Frame", {
        Name = "SliderBg",
        BackgroundColor3 = Color3.fromRGB(200, 180, 185),
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -20, 0, 6),
        Position = UDim2.new(0, 10, 0, 32),
        Parent = slider.Root,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 3)}, sliderBg)
    
    -- Slider fill
    local sliderFill = Create("Frame", {
        Name = "SliderFill",
        BackgroundColor3 = lib.Theme.AccentColor,
        BorderSizePixel = 0,
        Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
        Parent = sliderBg,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 3)}, sliderFill)
    
    -- Slider circle
    local sliderCircle = Create("Frame", {
        Name = "SliderCircle",
        BackgroundColor3 = lib.Theme.AccentColor,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(1, -8, 0, -5),
        Parent = sliderFill,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, sliderCircle)
    
    local dragging = false
    
    local function updateSlider(inputPos)
        local absPos = sliderBg.AbsolutePosition
        local absSize = sliderBg.AbsoluteSize.X
        local relativeX = Clamp((inputPos - absPos.X) / absSize, 0, 1)
        
        value = min + (max - min) * relativeX
        value = RoundNumber(value, 1)
        
        sliderFill.Size = UDim2.new(relativeX, 0, 1, 0)
        valueLabel.Text = tostring(value) .. suffix
        slider.Value = value
        
        if callback then
            pcall(callback, value)
        end
    end
    
    -- Mouse input
    local inputObj = Create("ImageButton", {
        BackgroundTransparency = 1,
        ImageTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = slider.Root,
    })
    
    inputObj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)
    
    inputObj.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    inputObj.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)
    
    -- Set value method
    slider.Set = function(self, val)
        value = Clamp(val, min, max)
        value = RoundNumber(value, 1)
        local percent = (value - min) / (max - min)
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        valueLabel.Text = tostring(value) .. suffix
        slider.Value = value
    end
    
    table.insert(self.Elements, slider)
    return slider
end

