function TabProto:UpdateTheme()
    local lib = self.Library
    
    for _, elem in ipairs(self.Elements) do
        if elem.Root then
            -- Update based on type
            if elem.Type == "Section" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local stroke = elem.Root:FindFirstChildWhichIsA("UIStroke")
                if stroke then stroke.Color = lib.Theme.BorderColor end
                local title = elem.Root:FindFirstChild("SectionTitle")
                if title then title.TextColor3 = lib.Theme.TitleColor end
            
            elseif elem.Type == "Button" then
                local btn = elem.Root:FindFirstChild("Button")
                if btn then
                    btn.BackgroundColor3 = lib.Theme.AccentColor
                    local stroke = btn:FindFirstChildWhichIsA("UIStroke")
                    if stroke then stroke.Color = lib.Theme.BorderColor end
                end
            
            elseif elem.Type == "Toggle" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local nameLabel = elem.Root:FindFirstChild("TextLabel")
                if nameLabel then nameLabel.TextColor3 = lib.Theme.TextColor end
                local toggleBg = elem.Root:FindFirstChild("ToggleBg")
                if toggleBg then
                    toggleBg.BackgroundColor3 = elem.Value and lib.Theme.AccentColor or Color3.fromRGB(180, 160, 165)
                end
            
            elseif elem.Type == "Slider" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local labels = elem.Root:GetChildren()
                for _, lbl in ipairs(labels) do
                    if lbl:IsA("TextLabel") then
                        if lbl.Position == UDim2.new(0, 10, 0, 6) then
                            lbl.TextColor3 = lib.Theme.TextColor
                        end
                    end
                end
                local sliderFill = elem.Root:FindFirstChild("SliderBg")
                if sliderFill then
                    local fill = sliderFill:FindFirstChild("SliderFill")
                    if fill then
                        fill.BackgroundColor3 = lib.Theme.AccentColor
                        local circle = fill:FindFirstChild("SliderCircle")
                        if circle then circle.BackgroundColor3 = lib.Theme.AccentColor end
                    end
                end
            
            elseif elem.Type == "ColorPicker" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local labels = elem.Root:GetChildren()
                for _, lbl in ipairs(labels) do
                    if lbl:IsA("TextLabel") and lbl.Position == UDim2.new(0, 10, 0, 8) then
                        lbl.TextColor3 = lib.Theme.TextColor
                    end
                end
                local expanded = elem.Root:FindFirstChild("ExpandedPicker")
                if expanded then
                    expanded.BackgroundColor3 = lib.Theme.Background2
                    local stroke = expanded:FindFirstChildWhichIsA("UIStroke")
                    if stroke then stroke.Color = lib.Theme.BorderColor end
                    local rgbText = expanded:FindFirstChild("TextLabel")
                    if rgbText then rgbText.TextColor3 = lib.Theme.TextColor end
                end
            
            elseif elem.Type == "Dropdown" or elem.Type == "MultiDropdown" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local labels = elem.Root:GetChildren()
                for _, lbl in ipairs(labels) do
                    if lbl:IsA("TextLabel") then
                        if lbl.Position == UDim2.new(0, 10, 0, 8) then
                            lbl.TextColor3 = lib.Theme.TextColor
                        elseif lbl.Text == "▼" or lbl.Text == "▲" then
                            lbl.TextColor3 = lib.Theme.IconColor
                        end
                    end
                end
                local display = elem.Root:FindFirstChild("TextLabel", true)
                if display and display.Position == UDim2.new(0, 110, 0, 6) then
                    display.BackgroundColor3 = lib.Theme.AccentColor
                    display.TextColor3 = lib.Theme.TextColor
                end
            
            elseif elem.Type == "Keybind" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local labels = elem.Root:GetChildren()
                for _, lbl in ipairs(labels) do
                    if lbl:IsA("TextLabel") and lbl.Position == UDim2.new(0, 10, 0, 8) then
                        lbl.TextColor3 = lib.Theme.TextColor
                    end
                end
                local keyBtn = elem.Root:FindFirstChild("TextButton")
                if keyBtn then
                    keyBtn.BackgroundColor3 = lib.Theme.AccentColor
                    keyBtn.TextColor3 = lib.Theme.TextColor
                end
            
            elseif elem.Type == "Input" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local labels = elem.Root:GetChildren()
                for _, lbl in ipairs(labels) do
                    if lbl:IsA("TextLabel") and lbl.Position == UDim2.new(0, 10, 0, 8) then
                        lbl.TextColor3 = lib.Theme.TextColor
                    end
                end
                local box = elem.Root:FindFirstChild("TextBox")
                if box then
                    box.BackgroundColor3 = lib.Theme.AccentColor
                    box.TextColor3 = lib.Theme.TextColor
                end
            
            elseif elem.Type == "Paragraph" then
                elem.Root.BackgroundColor3 = lib.Theme.Background
                local stroke = elem.Root:FindFirstChildWhichIsA("UIStroke")
                if stroke then stroke.Color = lib.Theme.BorderColor end
                local children = elem.Root:GetChildren()
                for _, child in ipairs(children) do
                    if child:IsA("TextLabel") then
                        if child.TextSize >= 14 then
                            child.TextColor3 = lib.Theme.TitleColor
                        else
                            child.TextColor3 = lib.Theme.TextColor
                        end
                    end
                end
            end
        end
    end
end

-- Notification system
function SakuraUI:Notify(title, text, duration)
    duration = duration or 3
    
    local notifContainer = self.ScreenGui:FindFirstChild("NotificationContainer")
    if not notifContainer then
        notifContainer = Create("Frame", {
            Name = "NotificationContainer",
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -340, 0, 20),
            Size = UDim2.new(0, 320, 1, -40),
            Parent = self.ScreenGui,
        })
    end
    
    local notif = Create("Frame", {
        Name = "Notification",
        BackgroundColor3 = self.Theme.Background,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 50),
        Position = UDim2.new(0, 0, 0, 0),
        ClipsDescendants = true,
        Parent = notifContainer,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 10)}, notif)
    Create("UIStroke", {Color = self.Theme.BorderColor, Thickness = 1, Transparency = 0.5, Parent = notif})
    
    local notifTitle = Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = self.Theme.TitleColor,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, 12, 0, 6),
        Size = UDim2.new(1, -24, 0, 18),
        Parent = notif,
    })
    
    local notifText = Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = self.Theme.TextColor,
        TextSize = 12,
        Font = Enum.Font.GothamLight,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Position = UDim2.new(0, 12, 0, 26),
        Size = UDim2.new(1, -24, 0, 20),
        Parent = notif,
    })
    
    -- Animate in
    Tween(notif, {BackgroundTransparency = 0}, TWEEN_FAST)
    notifTitle.TextTransparency = 1
    notifText.TextTransparency = 1
    Tween(notifTitle, {TextTransparency = 0}, TWEEN_FAST)
    Tween(notifText, {TextTransparency = 0}, TWEEN_FAST)
    
    -- Auto remove
    task.delay(duration, function()
        Tween(notif, {BackgroundTransparency = 1}, TWEEN_FAST)
        Tween(notifTitle, {TextTransparency = 1}, TWEEN_FAST)
        Tween(notifText, {TextTransparency = 1}, TWEEN_FAST)
        task.delay(0.3, function()
            notif:Destroy()
        end)
    end)
end

-- Destroy
function SakuraUI:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
    if self.Blur then
        self.Blur:Destroy()
    end
end

return SakuraUI
