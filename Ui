-- File handler
local FileHandler = {
    Enabled = pcall(function() return writefile end),
    
    Write = function(path, data)
        if not FileHandler.Enabled then return false end
        pcall(function()
            writefile(path, game:GetService("HttpService"):JSONEncode(data))
        end)
        return true
    end,
    
    Read = function(path)
        if not FileHandler.Enabled then return nil end
        local success, result = pcall(function()
            local content = readfile(path)
            return game:GetService("HttpService"):JSONDecode(content)
        end)
        if success then return result end
        return nil
    end,
    
    Exists = function(path)
        if not FileHandler.Enabled then return false end
        local success = pcall(function() return readfile(path) end)
        return success
    end
}

-- Utility functions
local function Create(class, properties, children)
    local obj = Instance.new(class)
    for k, v in pairs(properties or {}) do
        obj[k] = v
    end
    if children then
        for _, child in ipairs(children) do
            child.Parent = obj
        end
    end
    return obj
end

local function AddShadow(parent, transparency, color)
    local shadow = Create("ImageLabel", {
        Name = "Shadow",
        BackgroundTransparency = 1,
        Image = "rbxassetid://6014261993",
        ImageTransparency = transparency or 0.6,
        ImageColor3 = color or Color3.fromRGB(0, 0, 0),
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 50, 50),
        Size = UDim2.new(1, 20, 1, 20),
        Position = UDim2.new(0, -10, 0, -10),
        ZIndex = parent.ZIndex - 1,
        Parent = parent,
    })
    return shadow
end

local function RoundNumber(num, places)
    local mult = 10 ^ (places or 0)
    return math.floor(num * mult + 0.5) / mult
end

local function Clamp(val, min, max)
    return math.max(min, math.min(max, val))
end

local function LerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function RGBToHSV(color)
    local h, s, v = color:ToHSV()
    return h * 360, s, v
end

local function HSVToRGB(h, s, v)
    return Color3.fromHSV(h / 360, s, v)
end

-- Tween helper
local function Tween(obj, props, info)
    local tween = TweenService:Create(obj, info or TWEEN_INFO, props)
    tween:Play()
    return tween
end

-- Ripple effect
local function CreateRipple(button, color)
    local ripple = Create("Frame", {
        Name = "Ripple",
        BackgroundColor3 = color or Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.7,
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = button.ZIndex + 1,
        Parent = button,
    })
    
    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2
    Tween(ripple, {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1,
    }, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out))
    
    game:GetService("Debris"):AddItem(ripple, 0.6)
end

-- Main Library
function SakuraUI.new(config)
    config = config or {}
    local self = setmetatable({}, SakuraUI)
    
    self.Title = config.Title or "Sakura UI"
    self.Icon = config.Icon or 0
    self.Minimized = false
    self.Draggable = true
    self.Theme = {}
    self.Tabs = {}
    self.CurrentTab = nil
    self.Settings = {}
    
    -- Load saved settings
    self:LoadSettings()
    
    -- Merge theme
    for k, v in pairs(DEFAULT_THEME) do
        self.Theme[k] = self.Settings.Theme and self.Settings.Theme[k] or v
    end
    
    -- Apply saved colors
    if self.Settings.Theme then
        for k, v in pairs(self.Settings.Theme) do
            self.Theme[k] = v
        end
    end
    
    -- Create GUI
    self:BuildGUI()
    
    -- Select default tab
    if #self.Tabs > 0 then
        self:SelectTab(self.Tabs[1])
    end
    
    return self
end

