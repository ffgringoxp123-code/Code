function SakuraUI:UpdateTheme()
    -- Update main frame
    self.MainFrame.BackgroundColor3 = self.Theme.Background
    self.MainStroke.Color = self.Theme.BorderColor
    
    -- Update sidebar
    self.Sidebar.BackgroundColor3 = self.Theme.Sidebar
    self.UITitle.TextColor3 = self.Theme.TitleColor
    self.MinimizeBtn.ImageColor3 = self.Theme.IconColor
    
    -- Update content
    self.ContentArea.BackgroundColor3 = self.Theme.Background2
    self.TabTitle.TextColor3 = self.Theme.TitleColor
    
    -- Update all tabs
    for _, tab in ipairs(self.Tabs) do
        tab:UpdateTheme()
    end
    
    -- Update shadow
    local shadow = self.MainFrame:FindFirstChild("Shadow")
    if shadow then
        shadow.ImageColor3 = self.Theme.ShadowColor
    end
    
    -- Save
    self:SaveSettings()
end

function SakuraUI:ToggleMinimize()
    self.Minimized = not self.Minimized
    
    local targetSize
    local targetPos
    local bgTransparency
    local contentTransparency
    
    if self.Minimized then
        targetSize = UDim2.new(0, SIDEBAR_WIDTH, 0, 50)
        targetPos = UDim2.new(0.5, -SIDEBAR_WIDTH / 2, 0.5, -25)
        bgTransparency = 1
        contentTransparency = 1
    else
        targetSize = UDim2.new(0, SIDEBAR_WIDTH + CONTENT_WIDTH, 0, UI_HEIGHT)
        targetPos = UDim2.new(0.5, -(SIDEBAR_WIDTH + CONTENT_WIDTH) / 2, 0.5, -UI_HEIGHT / 2)
        bgTransparency = 0
        contentTransparency = 0
    end
    
    -- Tween main frame
    Tween(self.MainFrame, {
        Size = targetSize,
        Position = targetPos,
    }, TWEEN_SMOOTH)
    
    -- Tween content area
    if self.ContentArea then
        Tween(self.ContentArea, {
            BackgroundTransparency = bgTransparency,
        }, TWEEN_SMOOTH)
        
        -- Tween all children of content area
        for _, child in ipairs(self.ContentArea:GetChildren()) do
            if child:IsA("GuiObject") then
                Tween(child, {BackgroundTransparency = bgTransparency}, TWEEN_SMOOTH)
            end
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                Tween(child, {TextTransparency = bgTransparency}, TWEEN_SMOOTH)
            end
        end
    end
    
    -- Tween tab list
    if self.Minimized then
        Tween(self.TabList, {Size = UDim2.new(1, 0, 0, 0)}, TWEEN_SMOOTH)
        Tween(self.SidebarFooter, {BackgroundTransparency = 1}, TWEEN_SMOOTH)
        local footerLabel = self.SidebarFooter:FindFirstChild("VersionLabel")
        if footerLabel then
            Tween(footerLabel, {TextTransparency = 1}, TWEEN_SMOOTH)
        end
    else
        Tween(self.TabList, {Size = UDim2.new(1, 0, 1, -100)}, TWEEN_SMOOTH)
        Tween(self.SidebarFooter, {BackgroundTransparency = 0}, TWEEN_SMOOTH)
        local footerLabel = self.SidebarFooter:FindFirstChild("VersionLabel")
        if footerLabel then
            Tween(footerLabel, {TextTransparency = 0.4}, TWEEN_SMOOTH)
        end
    end
    
    -- Blur effect
    if self.Blur and self.Minimized then
        Tween(self.Blur, {Size = 0}, TWEEN_SMOOTH)
    elseif self.Blur and not self.Minimized then
        Tween(self.Blur, {Size = 8}, TWEEN_SMOOTH)
    end
end

function SakuraUI:MakeDraggable()
    local dragging = false
    local dragStart
    local startPos
    
    self.MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = self.MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    self.MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            self.MainFrame.Position = newPos
        end
    end)
end

-- Tab creation
function SakuraUI:CreateTab(name, icon)
    local tab = setmetatable({
        Library = self,
        Name = name,
        Icon = icon or 6031094678,
        Elements = {},
        LayoutOrder = #self.Tabs + 1,
    }, {__index = TabProto})
    
    -- Create tab button
    tab:BuildButton()
    
    table.insert(self.Tabs, tab)
    
    -- Update tab list canvas
    self.TabList.CanvasSize = UDim2.new(0, 0, 0, (#self.Tabs) * 38 + 10)
    
    return tab
end

-- Settings tab
function SakuraUI:CreateSettingsTab()
    local settingsTab = self:CreateTab("Settings", 6034629367)
    settingsTab.IsSettings = true
    
    -- Theme section
    local themeSection = settingsTab:CreateSection("Theme Colors")
    
    -- Color pickers
    local colorPickers = {
        {Name = "Main Color", Key = "MainColor"},
        {Name = "Accent Color", Key = "AccentColor"},
        {Name = "Border Color", Key = "BorderColor"},
        {Name = "Background Color", Key = "Background"},
    }
    
    for _, cp in ipairs(colorPickers) do
        local picker = settingsTab:CreateColorPicker(cp.Name, self.Theme[cp.Key], function(color)
            self.Theme[cp.Key] = color
            self:UpdateTheme()
        end)
        picker.ColorKey = cp.Key
    end
    
    -- Text colors section
    local textSection = settingsTab:CreateSection("Text Colors")
    
    local textPickers = {
        {Name = "Text Color", Key = "TextColor"},
        {Name = "Icon Color", Key = "IconColor"},
        {Name = "Title Color", Key = "TitleColor"},
    }
    
    for _, cp in ipairs(textPickers) do
        local picker = settingsTab:CreateColorPicker(cp.Name, self.Theme[cp.Key], function(color)
            self.Theme[cp.Key] = color
            self:UpdateTheme()
        end)
        picker.ColorKey = cp.Key
    end
    
    -- Reset theme button
    settingsTab:CreateButton("Reset Theme", function()
        for k, v in pairs(DEFAULT_THEME) do
            self.Theme[k] = v
        end
        self:UpdateTheme()
    end)
    
    return settingsTab
end

-- Save/Load settings
function SakuraUI:SaveSettings()
    local data = {
        Theme = self.Theme,
        Settings = self.Settings,
    }
    FileHandler.Write("SakuraUI_Settings.json", data)
end

function SakuraUI:LoadSettings()
    local data = FileHandler.Read("SakuraUI_Settings.json")
    if data then
        self.Settings = data.Settings or {}
        self.Settings.Theme = data.Theme or {}
    else
        self.Settings = {Theme = {}}
    end
end

