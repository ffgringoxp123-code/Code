    local picker = {Type = "ColorPicker", Root = nil, Value = color}
    
    picker.Root = Create("Frame", {
        Name = "ColorPickerFrame_" .. name,
        BackgroundTransparency = 0,
        BackgroundColor3 = lib.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        ClipsDescendants = true,
        LayoutOrder = #self.Elements + 1,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, picker.Root)
    
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = lib.Theme.TextColor,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, 10, 0, 8),
        Size = UDim2.new(0, 110, 0, 20),
        Parent = picker.Root,
    })
    
    -- Color preview
    local preview = Create("Frame", {
        Name = "ColorPreview",
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(0, 170, 0, 6),
        Parent = picker.Root,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, preview)
    
    -- Expanded picker
    local expandedFrame = Create("Frame", {
        Name = "ExpandedPicker",
        BackgroundColor3 = lib.Theme.Background2,
        BackgroundTransparency = 0.1,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 200, 0, 200),
        Position = UDim2.new(0, 10, 0, 36),
        Visible = false,
        ZIndex = 10,
        Parent = picker.Root,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, expandedFrame)
    Create("UIStroke", {Color = lib.Theme.BorderColor, Thickness = 1, Transparency = 0.5, Parent = expandedFrame})
    
    -- Color palette (2D)
    local h, s, v = RGBToHSV(color)
    
    local palette = Create("ImageLabel", {
        Name = "Palette",
        BackgroundTransparency = 0,
        BackgroundColor3 = HSVToRGB(h, 1, 1),
        Image = "rbxassetid://4155801252",
        Size = UDim2.new(0, 180, 0, 140),
        Position = UDim2.new(0, 10, 0, 10),
        ZIndex = 11,
        Parent = expandedFrame,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, palette)
    
    -- Palette selector
    local selector = Create("Frame", {
        Name = "Selector",
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 1,
        BorderColor3 = Color3.fromRGB(0, 0, 0),
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(s, -4, 1 - v, -4),
        ZIndex = 12,
        Parent = palette,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 4)}, selector)
    
    -- Hue slider
    local hueBg = Create("Frame", {
        Name = "HueBg",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 180, 0, 10),
        Position = UDim2.new(0, 10, 0, 158),
        Parent = expandedFrame,
    })
    
    local hueSlider = Create("ImageLabel", {
        BackgroundTransparency = 1,
        Image = "rbxassetid://3123698536",
        ScaleType = Enum.ScaleType.Stretch,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 11,
        Parent = hueBg,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 5)}, hueSlider)
    
    local hueSelector = Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 1,
        BorderColor3 = Color3.fromRGB(0, 0, 0),
        Size = UDim2.new(0, 6, 0, 14),
        Position = UDim2.new(h / 360, -3, 0, -2),
        ZIndex = 12,
        Parent = hueBg,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 3)}, hueSelector)
    
    -- RGB display
    local rgbLabel = Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = string.format("R: %d  G: %d  B: %d", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)),
        TextColor3 = lib.Theme.TextColor,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        Position = UDim2.new(0, 10, 0, 174),
        Size = UDim2.new(0, 140, 0, 18),
        ZIndex = 11,
        Parent = expandedFrame,
    })
    
    local function updateColor()
        color = HSVToRGB(h, s, v)
        preview.BackgroundColor3 = color
        rgbLabel.Text = string.format("R: %d  G: %d  B: %d", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))
        picker.Value = color
        if callback then
            pcall(callback, color)
        end
    end
    
    -- Palette drag
    local paletteDragging = false
    palette.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            paletteDragging = true
            local pos = input.Position
            local absPos = palette.AbsolutePosition
            local absSize = palette.AbsoluteSize
            s = Clamp((pos.X - absPos.X) / absSize.X, 0, 1)
            v = Clamp(1 - (pos.Y - absPos.Y) / absSize.Y, 0, 1)
            selector.Position = UDim2.new(s, -4, 1 - v, -4)
            updateColor()
        end
    end)
    
    palette.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            paletteDragging = false
        end
    end)
    
    palette.InputChanged:Connect(function(input)
        if paletteDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local pos = input.Position
            local absPos = palette.AbsolutePosition
            local absSize = palette.AbsoluteSize
            s = Clamp((pos.X - absPos.X) / absSize.X, 0, 1)
            v = Clamp(1 - (pos.Y - absPos.Y) / absSize.Y, 0, 1)
            selector.Position = UDim2.new(s, -4, 1 - v, -4)
            updateColor()
        end
    end)
    
    -- Hue drag
    local hueDragging = false
    -- Extended input area for hue
    local hueInput = Create("ImageButton", {
        BackgroundTransparency = 1,
        ImageTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 13,
        Parent = hueBg,
    })
    
    hueInput.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
            local pos = input.Position
            local absPos = hueBg.AbsolutePosition
            local absSize = hueBg.AbsoluteSize.X
            h = Clamp((pos.X - absPos.X) / absSize, 0, 1) * 360
            hueSelector.Position = UDim2.new(h / 360, -3, 0, -2)
            palette.BackgroundColor3 = HSVToRGB(h, 1, 1)
            updateColor()
        end
    end)
    
    hueInput.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)
    
    hueInput.InputChanged:Connect(function(input)
        if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local pos = input.Position
            local absPos = hueBg.AbsolutePosition
            local absSize = hueBg.AbsoluteSize.X
            h = Clamp((pos.X - absPos.X) / absSize, 0, 1) * 360
            hueSelector.Position = UDim2.new(h / 360, -3, 0, -2)
            palette.BackgroundColor3 = HSVToRGB(h, 1, 1)
            updateColor()
        end
    end)
    
    -- Toggle picker
    local toggleBtn = Create("ImageButton", {
        BackgroundTransparency = 1,
        ImageTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = picker.Root,
    })
    
    toggleBtn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            expandedFrame.Visible = true
            Tween(picker.Root, {Size = UDim2.new(1, 0, 0, 240)}, TWEEN_FAST)
        else
            Tween(picker.Root, {Size = UDim2.new(1, 0, 0, 36)}, TWEEN_FAST)
            task.delay(0.15, function()
                expandedFrame.Visible = false
            end)
        end
    end)
    
    picker.Set = function(self, newColor)
        color = newColor
        preview.BackgroundColor3 = color
        h, s, v = RGBToHSV(color)
        selector.Position = UDim2.new(s, -4, 1 - v, -4)
        hueSelector.Position = UDim2.new(h / 360, -3, 0, -2)
        palette.BackgroundColor3 = HSVToRGB(h, 1, 1)
        picker.Value = color
    end
    
    table.insert(self.Elements, picker)
    return picker
end

function TabProto:CreateKeybind(name, default, callback)
    local lib = self.Library
    local key = default or Enum.KeyCode.LeftControl
    local listening = false
    
    local kb = {Type = "Keybind", Root = nil, Value = key}
    
    kb.Root = Create("Frame", {
        Name = "KeybindFrame_" .. name,
        BackgroundTransparency = 0,
        BackgroundColor3 = lib.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        LayoutOrder = #self.Elements + 1,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, kb.Root)
    
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = lib.Theme.TextColor,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, 10, 0, 8),
        Size = UDim2.new(0, 110, 0, 20),
        Parent = kb.Root,
    })
    
    local keyDisplay = Create("TextButton", {
        BackgroundTransparency = 0.9,
        BackgroundColor3 = lib.Theme.AccentColor,
        Text = key.Name or "None",
        TextColor3 = lib.Theme.TextColor,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        Position = UDim2.new(0, 140, 0, 6),
        Size = UDim2.new(0, 80, 0, 24),
        AutoButtonColor = false,
        Parent = kb.Root,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, keyDisplay)
    Create("UIStroke", {Color = lib.Theme.BorderColor, Thickness = 1, Transparency = 0.5, Parent = keyDisplay})
    
    keyDisplay.MouseButton1Click:Connect(function()
        listening = not listening
        keyDisplay.Text = listening and "..." or (key.Name or "None")
        Tween(keyDisplay, {BackgroundColor3 = listening and lib.Theme.AccentColor or lib.Theme.Background, BackgroundTransparency = listening and 0.7 or 0.9}, TWEEN_FAST)
    end)
    
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if listening then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                key = input.KeyCode
                kb.Value = key
                keyDisplay.Text = key.Name
                keyDisplay.BackgroundColor3 = lib.Theme.Background
                keyDisplay.BackgroundTransparency = 0.9
                if callback then
                    pcall(callback, key)
                end
            end
        end
    end)
    
    kb.Set = function(self, newKey)
        key = newKey
        kb.Value = key
        keyDisplay.Text = key.Name or "None"
    end
    
    table.insert(self.Elements, kb)
    return kb
end

function TabProto:CreateInput(name, placeholder, default, callback)
    local lib = self.Library
    local text = default or ""
    
    local input = {Type = "Input", Root = nil, Value = text}
    
    input.Root = Create("Frame", {
        Name = "InputFrame_" .. name,
        BackgroundTransparency = 0,
        BackgroundColor3 = lib.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 36),
        LayoutOrder = #self.Elements + 1,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 8)}, input.Root)
    
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = lib.Theme.TextColor,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, 10, 0, 8),
        Size = UDim2.new(0, 100, 0, 20),
        Parent = input.Root,
    })
    
    local textBox = Create("TextBox", {
        ClearTextOnFocus = false,
        BackgroundTransparency = 0.9,
        BackgroundColor3 = lib.Theme.AccentColor,
        Text = text,
        TextColor3 = lib.Theme.TextColor,
        TextSize = 12,
        Font = Enum.Font.GothamMedium,
        PlaceholderText = placeholder or "Enter value...",
        PlaceholderColor3 = Color3.fromRGB(180, 150, 160),
        Position = UDim2.new(0, 110, 0, 6),
        Size = UDim2.new(0, 110, 0, 24),
        Parent = input.Root,
    })
    
    Create("UICorner", {CornerRadius = UDim.new(0, 6)}, textBox)
    Create("UIStroke", {Color = lib.Theme.BorderColor, Thickness = 1, Transparency = 0.5, Parent = textBox})
    
    textBox.FocusLost:Connect(function(enterPressed)
        text = textBox.Text
        input.Value = text
        if callback then
            pcall(callback, text)
        end
    end)
    
    input.Set = function(self, newText)
        text = tostring(newText)
        input.Value = text
        textBox.Text = text
    end
    
    table.insert(self.Elements, input)
    return input
end

