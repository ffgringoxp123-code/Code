-- Select tab
function SakuraUI:SelectTab(tab)
    if self.CurrentTab == tab then return end
    
    -- Deselect previous
    if self.CurrentTab then
        Tween(self.CurrentTab.Button, {BackgroundTransparency = 0.85}, TWEEN_FAST)
        Tween(self.CurrentTab.Indicator, {BackgroundTransparency = 0.5}, TWEEN_FAST)
        
        -- Fade out content
        for _, elem in ipairs(self.CurrentTab.Elements) do
            if elem.Root and elem.Root.Parent then
                Tween(elem.Root, {BackgroundTransparency = 1, GroupTransparency = 1}, TWEEN_FAST)
                -- Also tween text
                for _, child in ipairs(elem.Root:GetDescendants()) do
                    if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                        Tween(child, {TextTransparency = 1}, TWEEN_FAST)
                    end
                    if child:IsA("ImageLabel") or child:IsA("ImageButton") then
                        Tween(child, {ImageTransparency = 1}, TWEEN_FAST)
                    end
                end
            end
        end
        
        -- Delay removing
        task.delay(0.15, function()
            for _, elem in ipairs(self.CurrentTab.Elements) do
                if elem.Root then
                    elem.Root.Parent = nil
                end
            end
        end)
    end
    
    self.CurrentTab = tab
    
    -- Update header
    Tween(self.TabTitle, {TextTransparency = 1}, TWEEN_FAST)
    task.delay(0.1, function()
        self.TabTitle.Text = tab.Name
        Tween(self.TabTitle, {TextTransparency = 0}, TWEEN_FAST)
    end)
    
    -- Select new
    Tween(tab.Button, {BackgroundTransparency = 0.65}, TWEEN_FAST)
    Tween(tab.Indicator, {BackgroundTransparency = 0}, TWEEN_FAST)
    
    -- Show elements with stagger
    task.delay(0.15, function()
        for i, elem in ipairs(tab.Elements) do
            elem.Root.Parent = self.ElementContainer
            elem.Root.BackgroundTransparency = 1
            elem.Root.GroupTransparency = 1
            
            task.delay(i * 0.03, function()
                Tween(elem.Root, {BackgroundTransparency = 0, GroupTransparency = 0}, TWEEN_FAST)
                for _, child in ipairs(elem.Root:GetDescendants()) do
                    if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                        child.TextTransparency = 1
                        Tween(child, {TextTransparency = 0}, TWEEN_FAST)
                    end
                    if child:IsA("ImageLabel") or child:IsA("ImageButton") then
                        child.ImageTransparency = 1
                        Tween(child, {ImageTransparency = 0}, TWEEN_FAST)
                    end
                end
            end)
        end
    end)
end

