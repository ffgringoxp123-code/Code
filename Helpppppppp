local function findNet()
    local pkg = ReplicatedStorage:FindFirstChild("Packages")
    if not pkg then return end
    local idx = pkg:FindFirstChild("_Index")
    if not idx then return end
    for _, v in pairs(idx:GetChildren()) do
        if v.Name:find("sleitnick_net") then
            local n = v:FindFirstChild("net")
            if n then return n end
        end
    end
end

local net = findNet()
if net then
    local re = net:FindFirstChild("RE")
    if re then
        local thA = re:FindFirstChild("TimeHoleActivate")
        local thD = re:FindFirstChild("TimeHoleDeactivate")
        local fA = re:FindFirstChild("SlashesOfFuryActivate")
        local fE = re:FindFirstChild("SlashesOfFuryEnd")
        local fP = re:FindFirstChild("SlashesOfFuryParry")
        local fC = re:FindFirstChild("SlashesOfFuryCatch")
        
        if thA then thA.OnClientEvent:Connect(function(...)
            local a = {...}; local p = a[1]
            if p == LP or p == LP.Name then St.th = true end
        end) end
        if thD then thD.OnClientEvent:Connect(function() St.th = false end) end
        if fA then fA.OnClientEvent:Connect(function(...)
            local a = {...}; local p = a[1]
            if p == LP or p == LP.Name then St.fury = true; St.fc = 0 end
        end) end
        if fE then fE.OnClientEvent:Connect(function() St.fury = false; St.fc = 0 end) end
        if fP then fP.OnClientEvent:Connect(function() St.fc = (St.fc or 0) + 1 end) end
        if fC then fC.OnClientEvent:Connect(function()
            spawn(function()
                while St.fury and (St.fc or 0) < 36 do exec_parry(); task.wait(0.05) end
            end)
        end) end
    end
end

local apRunning = false

function startAP()
    if apRunning then return end
    apRunning = true
    
    St.divisor = 0.75 + (getgenv().AutoParry_Accuracy - 1) * (3/99)
    
    task.spawn(function()
        while apRunning and getgenv().AutoParry_Enabled do
            task.wait()
            if not LP.Character or not LP.Character.PrimaryPart then continue end
            
            local balls = get_balls()
            local one = get_ball()
            
            for _, ball in pairs(balls) do
                if not ball then continue end
                local z = ball:FindFirstChild('zoomies')
                if not z then continue end
                
                local tgt = ball:GetAttribute('target')
                local vel = z.VectorVelocity
                local lat = Stats.Network.ServerStatsItem['Data Ping']:GetValue() / 1000
                local pred = ball.Position + vel * lat
                local dist = (LP.Character.PrimaryPart.Position - pred).Magnitude
                local ping = Stats.Network.ServerStatsItem['Data Ping']:GetValue() / 10
                local pT = math.clamp(ping / 10, 5, 17)
                local spd = vel.Magnitude
                local csd = math.min(math.max(spd - 9.5, 0), 650)
                local sd = (2.4 + csd * 0.002) * St.divisor
                local acc = pT + math.max(spd / sd, 
                if ball:FindFirstChild('AeroDynamicSlashVFX') then
                    ball.AeroDynamicSlashVFX:Destroy()
                    St.torn = tick()
                end
                
                if RT:FindFirstChild('Tornado') and (tick() - (St.torn or tick())) < (RT.Tornado:GetAttribute('TornadoTime') or 1) + 0.314 then
                    continue
                end
                
                if ball:FindFirstChild('ComboCounter') then continue end
                if LP.Character.PrimaryPart:FindFirstChild('SingularityCape') then continue end
                if St.inf or St.ds or St.th or St.fury then continue end
                
                if tgt == LP.Name and dist <= acc then
                    if getgenv().AutoParry_Cooldown then
                        local cd = LP.PlayerGui.Hotbar.Block.UIGradient
                        if cd.Offset.Y < 0.4 then
                            ReplicatedStorage.Remotes.AbilityButtonPress:Fire()
                            continue
                        end
                    end
                  
                    if getgenv().AutoParry_Ability then
                        local acd = LP.PlayerGui.Hotbar.Ability.UIGradient
                        if acd.Offset.Y == 0.5 then
                            local ab = LP.Character:FindFirstChild("Abilities")
                            if ab then
                                local ok = (ab:FindFirstChild("Raging Deflection") and ab["Raging Deflection"].Enabled) or
                                    (ab:FindFirstChild("Rapture") and ab["Rapture"].Enabled) or
                                    (ab:FindFirstChild("Calming Deflection") and ab["Calming Deflection"].Enabled) or
                                    (ab:FindFirstChild("Aerodynamic Slash") and ab["Aerodynamic Slash"].Enabled) or
                                    (ab:FindFirstChild("Fracture") and ab["Fracture"].Enabled) or
                                    (ab:FindFirstChild("Death Slash") and ab["Death Slash"].Enabled)
                                if ok then
                                    St.parried = true
                                    ReplicatedStorage.Remotes.AbilityButtonPress:Fire()
                                    task.wait(2.432)
                                    pcall(function() ReplicatedStorage.Remotes.DeathSlashShootActivation:FireServer(true) end)
                                    continue
                                end
                            end
                        end
                    end
                    
                    parry_action()
                    task.wait(0.5)
                end
            end
        end
        apRunning = false
    end)
end

function stopAP()
    apRunning = false
end

local asRunning = false

function startAS()
    if asRunning then return end
    asRunning = true
    
    task.spawn(function()
        while asRunning and getgenv().AutoSpam_Enabled do
            task.wait()
            
            local ball = get_ball()
            if not ball then continue end
            if St.fury then continue end
            
            local z = ball:FindFirstChild('zoomies')
            if not z then continue end
            
            -- Tìm người chơi gần nhất
            local closest, maxD = nil, math.huge
            if Alive then
                for _, e in pairs(Alive:GetChildren()) do
                    if e ~= LP.Character and e.PrimaryPart then
                        local d = LP:DistanceFromCharacter(e.PrimaryPart.Position)
                        if d < maxD then maxD = d; closest = e end
                    end
                end
            end
            if not closest then continue end
            
            local ping = Stats.Network.ServerStatsItem['Data Ping']:GetValue()
            local pT = math.clamp(ping / 10, 1, 16)
            local tgt = ball:GetAttribute('target')
            if not tgt then continue end
            
            local tD = LP:DistanceFromCharacter(closest.PrimaryPart.Position)
            local d = LP:DistanceFromCharacter(ball.Position)
            local dir = (LP.Character.PrimaryPart.Position - ball.Position).Unit
            local bD = z.VectorVelocity.Unit
            local dot = dir:Dot(bD)
            local spd = z.VectorVelocity.Magnitude
            local mSD = pT + math.min(spd / 6, 255)
            local mS = 5 - math.min(spd / 5, 5)
            local mD = math.clamp(dot, -1, 0) * mS
            local acc = mSD - mD
            
            if tD > acc or d > acc then continue end
            if LP.Character:GetAttribute('Pulsed') then continue end
            if tgt == LP.Name and tD > 30 and d > 30 then continue end
            
            if d <= acc and St.parries > getgenv().AutoSpam_Threshold then
                if getgenv().AutoSpam_Mode == "Keypress" then
                    if PF then PF() end
                else
                    exec_parry()
                    if getgenv().AutoSpam_AnimFix and PF then PF() end
                end
            end
        end
        asRunning = false
    end)
end

function stopAS()
    asRunning = false
end

