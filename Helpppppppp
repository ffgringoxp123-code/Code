local function send_parry()
    if St.parries > 10000 then return end
    pcall(function()
        VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
        task.defer(function() pcall(function() VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game) end) end)
    end)
    St.parries = St.parries + 1
    task.delay(0.5, function() if St.parries > 0 then St.parries = St.parries - 1 end end)
end

local function exec_parry()
    if St.parries > 10000 or not LP.Character then return end
    if getgenv().AutoParry_Mode == "Keypress" then
        if PF then PF() end
    else
        send_parry()
    end
end

local function play_anim()
    local char = LP.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass('Humanoid')
    local anim = hum and hum:FindFirstChildOfClass('Animator')
    if not hum or not anim then return end
    
    local sword = char:GetAttribute('CurrentlyEquippedSword')
    if not sword then return end
    
    local api = ReplicatedStorage:FindFirstChild("Shared")
    if api then
        api = api:FindFirstChild("SwordAPI")
        if api then api = api:FindFirstChild("Collection") end
    end
    if not api then return end
    
    local pa = api:FindFirstChild('Default')
    if pa then pa = pa:FindFirstChild('GrabParry') end
    if not pa then return end
    
    local data = ReplicatedStorage:FindFirstChild("Shared")
    if data then
        data = data:FindFirstChild("ReplicatedInstances")
        if data then data = data:FindFirstChild("Swords")
            if data then data = data:FindFirstChild("GetSword") end
        end
    end
    if data then
        local success, swordData = pcall(function() return data:Invoke(sword) end)
        if success and swordData and swordData['AnimationType'] then
            for _, o in pairs(api:GetChildren()) do
                if o.Name == swordData['AnimationType'] then
                    if o:FindFirstChild('GrabParry') then pa = o.GrabParry
                    elseif o:FindFirstChild('Grab') then pa = o.Grab end
                end
            end
        end
    end
    
    if St.gAnim and St.gAnim.IsPlaying then St.gAnim:Stop() end
    St.gAnim = anim:LoadAnimation(pa)
    St.gAnim.Priority = Enum.AnimationPriority.Action4
    St.gAnim:Play()
end

local function parry_action()
    play_anim()
    exec_parry()
end

local function get_ball()
    local b = workspace:FindFirstChild('Balls')
    if b then
        for _, v in pairs(b:GetChildren()) do
            if v:GetAttribute('realBall') then return v end
        end
    end
    return nil
end

local function get_balls()
    local t = {}
    local b = workspace:FindFirstChild('Balls')
    if b then
        for _, v in pairs(b:GetChildren()) do
            if v:GetAttribute('realBall') then table.insert(t, v) end
        end
    end
    return t
end

