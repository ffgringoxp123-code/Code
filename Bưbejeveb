local function fire_net_remote(cframe, event_data, aim_target)
    if not get_remote_not then return end
    local time_hash = (function()
        local get_t_net = ""
        local server_time = math.floor(workspace:GetServerTimeNow() * 100)
        for i = 1, #tostring(server_time) do
            get_t_net = get_t_net .. string.char(bit32.bxor(
                (tostring(server_time):byte(i) + i) % 256,
                get_key_net_time(get_num_net, "TIME"):byte((i - 1) % #get_key_net_time(get_num_net, "TIME") + 1)
            ))
        end
        return get_t_net
    end)()
    get_remote_not:FireServer(
        get_hash_net, get_hash_parry, time_hash, get_num_not or 0,
        cframe or workspace.CurrentCamera.CFrame,
        event_data or {},
        aim_target or {UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y},
        false
    )
end

