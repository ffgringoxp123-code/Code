        end
        if tb then
            local z = tb:FindFirstChild('zoomies')
            if z then
                tb:GetAttributeChangedSignal('target'):Once(function() System.__properties.__training_parried = false end)
                if not System.__properties.__training_parried then
                    local bt = tb:GetAttribute('target'); local vel = z.VectorVelocity; local dist = LocalPlayer:DistanceFromCharacter(tb.Position)
                    local speed = vel.Magnitude; local ping = Stats.Network.ServerStatsItem['Data Ping']:GetValue()/10; local pt = math.clamp(ping/10,5,17)
                    local capped = math.min(math.max(speed-9.5,0),650); local div = (2.4 + capped*0.002) * System.__properties.__divisor_multiplier; local pa = pt + math.max(speed/div,9.5)
                    if bt == LocalPlayer.Name and dist <= pa then execute_parry(mode); play_grab_parry(); System.__properties.__training_parried = true; local t = tick(); repeat RunService.Stepped:Wait() until (tick()-t) >= 1 or not System.__properties.__training_parried; System.__properties.__training_parried = false end
                end
