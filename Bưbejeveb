    local b = get_ball(); if not b then return false end; local c = LocalPlayer.Character; if not c or not c.PrimaryPart then return false end
    local d = c.PrimaryPart.Position - b.Position; local bv = b.AssemblyLinearVelocity or Vector3.zero; return {Velocity = bv, Direction = d.Unit, Distance = d.Magnitude, Dot = d.Unit:Dot(bv.Unit)}
end
local function spam_svc(bp, ep, ping)
    local b = get_ball(); local e = get_closest_player(); if not b or not e or not e.PrimaryPart then return 0 end
    local vel = b.AssemblyLinearVelocity or Vector3.zero; local sp = vel.Magnitude
    local dir = (LocalPlayer.Character.PrimaryPart.Position - b.Position).Unit; local dot = dir:Dot(vel.Unit)
    local td = LocalPlayer:DistanceFromCharacter(e.PrimaryPart.Position)
    local mult = System.__properties.__auto_spam_distance_multiplier or 1.0; local base = 30 * mult; local maxd = (ping + math.min(sp/4,60)) * mult
    if ep.Distance > maxd and ep.Distance > base then return 0 end; if bp.Distance > maxd and bp.Distance > base then return 0 end; if td > maxd and td > base then return 0 end
    local ms = 7 - math.min(sp/5,5); local mdot = math.clamp(dot,-1,1) * ms; return maxd - mdot
end
function System.auto_spam.start()
    if System.__properties.__connections.__auto_spam then System.__properties.__connections.__auto_spam:Disconnect() end
    System.__properties.__auto_spam_enabled = true; System.__properties.__first_parry_done = false
    local mode = getgenv().AutoSpamMode or "Remote"; local ls = 0; local lc = 0
    System.__properties.__connections.__auto_spam = RunService.Heartbeat:Connect(function()
        local c = LocalPlayer.Character; if not System.__properties.__auto_spam_enabled or not c or c.Parent ~= Alive then return end
        local n = tick(); if n - ls < 0.015 then return end; ls = n; local b = get_ball(); if not b then return end; local z = b:FindFirstChild('zoomies'); if not z then return end
        if n - lc > 0.1 then
            get_closest_player(); lc = n
            if System.__properties.__spam_target then local t = System.__properties.__spam_target; if not t.Parent or not t:FindFirstChild("Humanoid") or t.Humanoid.Health <= 0 then System.__properties.__spam_target = nil; System.__properties.__spam_target_time = 0 end end
            if not System.__properties.__spam_target or (n - System.__properties.__spam_target_time > 1) then System.__properties.__spam_target = Closest_Entity; System.__properties.__spam_target_time = n end
        end
        local bt = b:GetAttribute('target'); if not bt then return end; local bp = get_bp(); local ep = get_ep()
        if bp and ep then
            local ping = Stats.Network.ServerStatsItem['Data Ping']:GetValue(); local pt = math.clamp(ping/5,1,16); local acc = spam_svc(bp, ep, pt)
            if acc > 0 then
                local r = c.PrimaryPart; if not r then return end; local te = Closest_Entity; if not te or not te.PrimaryPart then return end
                local td = (r.Position - te.PrimaryPart.Position).Magnitude; local db = (r.Position - b.Position).Magnitude; local should = false
                if System.__properties.__spam_target and (bt == System.__properties.__spam_target.Name or bt == LocalPlayer.Name) then should = true end
                if should and not c:GetAttribute('Pulsed') and td <= acc and db <= acc then
                    local mult = System.__properties.__auto_spam_distance_multiplier or 1.0; local ma = 35 * mult; local ist = bt == LocalPlayer.Name; local fm = ist and ma or (ma * 0.8)
                    if td <= fm and db <= fm and System.__properties.__parries <= System.__properties.__max_parries then execute_parry(mode); if getgenv().AutoSpamAnimationFix then play_grab_parry() end end
                end
            end
        end
    end)
end
function System.auto_spam.stop()
    System.__properties.__auto_spam_enabled = false; System.__properties.__spam_target = nil; System.__properties.__spam_target_time = 0
    if System.__properties.__connections.__auto_spam then System.__properties.__connections.__auto_spam:Disconnect(); System.__properties.__connections.__auto_spam = nil end
end

