local function parry_fireserver()
    if System.__properties.__parries > System.__properties.__max_parries or not LocalPlayer.Character then return end
    local camera = workspace.CurrentCamera; local s, m = pcall(function() return UserInputService:GetMouseLocation() end)
    if not s then return end
    local vec = {m.X, m.Y}; local mobile = System.__properties.__is_mobile; local ed = {}
    if Alive then
        for _, e in pairs(Alive:GetChildren()) do
            if e.PrimaryPart then local s2, sp = pcall(function() return camera:WorldToScreenPoint(e.PrimaryPart.Position) end); if s2 then ed[e.Name] = sp end end
        end
    end
    local cf = get_curve_cframe()
    if not System.__properties.__first_parry_done then
        for _, c in pairs(getconnections(LocalPlayer.PlayerGui.Hotbar.Block.Activated)) do c:Fire() end
        System.__properties.__first_parry_done = true; return
    end
    local aim = mobile and {camera.ViewportSize.X/2, camera.ViewportSize.Y/2} or vec
    for r, oa in pairs(revertedRemotes) do
        local args = {oa[1], oa[2], oa[3], cf, ed, aim, oa[7]}
        pcall(function() if r:IsA('RemoteEvent') then r:FireServer(unpack(args)) elseif r:IsA('RemoteFunction') then r:InvokeServer(unpack(args)) end end)
    end
    fire_net_remote(cf, ed, aim)
    if System.__properties.__parries > System.__properties.__max_parries then return end
    System.__properties.__parries = System.__properties.__parries + 1
    task.delay(0.5, function() if System.__properties.__parries > 0 then System.__properties.__parries = System.__properties.__parries - 1 end end)
end

