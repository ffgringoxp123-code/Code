local function get_curve_cframe()
    local camera = workspace.CurrentCamera; local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
    if not root then return camera.CFrame end
    local targetPart; local closest = get_closest_to_cursor()
    if closest and closest:FindFirstChild('HumanoidRootPart') then targetPart = closest.HumanoidRootPart end
    local tpos = targetPart and targetPart.Position or (root.Position + camera.CFrame.LookVector * 100)
    local funcs = {
        function() return camera.CFrame end,
        function()
            local dir = (tpos - root.Position).Unit; local off; local at = 0
            repeat off = Vector3.new(math.random(-4000,4000), math.random(-4000,4000), math.random(-4000,4000)); at = at + 1 until dir:Dot((tpos + off - root.Position).Unit) < 0.95 or at > 10
            return CFrame.new(root.Position, tpos + off)
        end,
        function() return CFrame.new(root.Position, tpos + Vector3.new(0,5,0)) end,
        function() local d = (root.Position - tpos).Unit; return CFrame.new(camera.CFrame.Position, root.Position + d * 10000 + Vector3.new(0,1000,0)) end,
        function() return CFrame.new(root.Position, tpos + Vector3.new(0,-9e18,0)) end,
        function() return CFrame.new(root.Position, tpos + Vector3.new(0,9e18,0)) end
