local function linear_predict(a,b,t) return a + (b-a)*t end
local function is_curved()
    local bp = System.__detection.__ball_properties; local ball = get_ball()
    if not ball then return false end; local z = ball:FindFirstChild('zoomies')
    if not z then return false end
    local vel = z.VectorVelocity; local bd = vel.Unit
    local dir = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Unit; local dot = dir:Dot(bd)
    local speed = vel.Magnitude; local st = math.min(speed/100,40)
    local dd = (bd - vel).Unit; local ds = dir:Dot(dd); local dod = dot - ds
    local dist = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Magnitude
    local ping = Stats.Network.ServerStatsItem['Data Ping']:GetValue(); local dott = 0.5 - (ping/1000)
    local rt = dist/speed - (ping/1000); local bdt = 15 - math.min(dist/1000,15) + st
    local cl = math.clamp(dot,-1,1); local rad = math.rad(math.asin(cl))
    bp.__lerp_radians = linear_predict(bp.__lerp_radians, rad, 0.8)
    if speed > 0 and rt > ping/10 then bdt = math.max(bdt - 15, 15) end
    if dist < bdt then return false end; if dod < dott then return true end
    if bp.__lerp_radians < 0.018 then bp.__last_warping = tick() end
    if (tick() - bp.__last_warping) < (rt/1.5) then return true end
    if (tick() - bp.__curving) < (rt/1.5) then return true end
    return dot < dott
end

